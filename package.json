{
  "name": "@sonmily/design-system",
  "version": "1.0.0",
  "description": "손밀리 기업 디자인 시스템 - BOKHAUS 시니어 UX 우선",
  "main": "index.ts",
  "types": "index.ts",
  "scripts": {
    "build:tokens": "style-dictionary build --config config/style-dictionary.config.js",
    "watch:tokens": "nodemon --watch tokens --exec npm run build:tokens",
    "build": "npm run build:tokens && tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf build/ dist/",
    "prebuild": "npm run clean",
    "test": "jest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "postinstall": "npm run build:tokens"
  },
  "dependencies": {
    "react-native-paper": "^5.12.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-actions": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-webpack5": "^8.6.18",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "nodemon": "^3.0.0",
    "storybook": "^8.6.18",
    "style-dictionary": "^3.9.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "react-native",
    "bokhaus",
    "senior-ux",
    "accessibility"
  ],
  "author": "CTO, Sonmily Corp",
  "license": "MIT",
  "exports": {
    ".": {
      "react-native": "./index.ts",
      "default": "./dist/index.js",
      "types": "./index.ts"
    }
  }
}
