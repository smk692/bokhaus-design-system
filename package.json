{
  "name": "@sonmily/design-system",
  "version": "0.4.0",
  "description": "손밀리 기업 디자인 시스템 - BOKHAUS 시니어 UX 우선",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:tokens": "style-dictionary build --config config/style-dictionary.config.js",
    "watch:tokens": "nodemon --watch tokens --exec npm run build:tokens",
    "build": "npm run build:tokens && tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf build/ dist/",
    "prebuild": "npm run clean",
    "test": "jest",
    "postinstall": "npm run build:tokens"
  },
  "dependencies": {
    "react-native-paper": "^5.12.0"
  },
  "devDependencies": {
    "style-dictionary": "^3.9.0",
    "nodemon": "^3.0.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "react-native",
    "bokhaus",
    "senior-ux",
    "accessibility"
  ],
  "author": "CTO, Sonmily Corp",
  "license": "MIT"
}
